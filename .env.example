DATABASE_URL=postgres://oxinbox:oxinbox_dev@localhost:5432/oxinbox

# OIDC provider (PocketId)
OIDC_ISSUER_URL=http://localhost:8765
OIDC_CLIENT_ID=oxinbox
# OIDC_CLIENT_SECRET=<generated by scripts/setup-auth.sh>

# AI provider: openrouter (default) or openai
AI_PROVIDER=openrouter
AI_API_KEY=sk-or-v1-...
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=deepseek/deepseek-v4-flash
AI_EMBEDDING_MODEL=baai/bge-m3
AI_WHISPER_MODEL=qwen/qwen3-asr-flash-2026-02-10

# Server
# PORT=3300

# Logging
RUST_LOG=info
# TRACING_FORMAT=json

# Web Push (VAPID)
# VAPID_PRIVATE_KEY=<base64 of DER private key>
# VAPID_CONTACT=mailto:admin@example.com